# Frontend country instance variables for Cloudflare Pages.
# Set these in the Pages project, not as Worker secrets.

VITE_SITE_COUNTRY=ES
VITE_SITE_LOCALE=es-ES
VITE_SITE_SEO_LOCALE=es-es
VITE_SITE_TIMEZONE=Europe/Madrid
VITE_SITE_CURRENCY=EUR
VITE_SITE_ORIGIN=https://es.mansiondeseo.com
VITE_SITE_MEDIA_BASE=https://media-es.mansiondeseo.com
VITE_API_BASE=https://mansion-deseo-api-es.<account-subdomain>.workers.dev/api
VITE_WS_BASE=wss://mansion-deseo-api-es.<account-subdomain>.workers.dev
VITE_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
