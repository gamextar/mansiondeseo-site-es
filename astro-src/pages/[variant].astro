---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SEO_INTENT_VARIANTS, isSeoIntentVariant } from '../../src/lib/seoVariants.js';
import { getAstroLandingData, RELATED_KEYWORDS } from '../lib/landingData.js';
import { APP_SITE_ORIGIN } from '../../src/lib/siteDomains.js';

export function getStaticPaths() {
  return SEO_INTENT_VARIANTS.map((variant) => ({ params: { variant } }));
}

const { variant } = Astro.params;

if (!isSeoIntentVariant(variant)) {
  throw new Error(`Invalid SEO variant: ${variant}`);
}

const { localeConfig, page, canonical, alternates, faqSchema, pageSchema } = getAstroLandingData({ variant });
const keywordPills = ['encuentros discretos', 'perfiles verificados', 'adultos registrados', 'contactos privados'];
---
<BaseLayout
  title={page.title}
  description={page.description}
  canonical={canonical}
  alternates={alternates}
  htmlLang={localeConfig.language}
  ogLocale={localeConfig.hreflang.replace('-', '_')}
  schemas={[faqSchema, pageSchema]}
>
  <main class="page-frame">
    <div class="page-background">
      <div class="background-blob left"></div>
      <div class="background-blob right"></div>
    </div>

    <div class="page-shell section-spaced" style="position:relative;">
      <header class="topbar" style="padding-top:0;margin-bottom:40px;">
        <a class="brand" href="/">
          <span class="brand-mark">M</span>
          <span>
            <strong class="brand-title">Mansión Deseo</strong>
            <span class="dim" style="display:block;font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;">Acceso privado para adultos</span>
          </span>
        </a>

        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a class="secondary-button" href={`${APP_SITE_ORIGIN}/login`}>Iniciar sesión</a>
          <a class="primary-button" href={`${APP_SITE_ORIGIN}/registro`}>Registrarme</a>
        </div>
      </header>

      <section class="landing-hero-grid">
        <section>
          <div class="tag-list">
            <span class="pill"><span class="pill-dot"></span>Solo mayores registrados</span>
            <span class="pill"><span class="pill-dot"></span>Perfiles verificados</span>
            <span class="pill"><span class="pill-dot"></span>Discreción total</span>
          </div>

          <h1 class="headline" style="max-width:18ch;">{page.headline}</h1>
          <p class="subheadline">{page.intro}</p>

          <div class="tag-list" style="margin-top:20px;">
            {keywordPills.map((item) => (
              <span class="tag-link">{item}</span>
            ))}
          </div>

          <div class="feature-grid">
            <div class="card">
              <div class="feature-icon">P</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Comunidad privada</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">El contenido completo vive dentro de la app y se abre solo para usuarios registrados.</p>
            </div>
            <div class="card">
              <div class="feature-icon">A</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Afinidad real</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">Cada landing conecta una búsqueda concreta con una experiencia más cuidada y privada.</p>
            </div>
            <div class="card">
              <div class="feature-icon">C</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Experiencia cuidada</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">Sin ruido visual de la app, pero con un puente claro hacia registro y acceso completo.</p>
            </div>
          </div>

          <div class="button-row">
            <a class="primary-button" href={`${APP_SITE_ORIGIN}/registro`}>Crear cuenta</a>
            <a class="secondary-button" href={`${APP_SITE_ORIGIN}/login`}>Ya tengo cuenta</a>
          </div>
        </section>

        <aside class="surface" style="padding:28px;border-radius:32px;background:linear-gradient(180deg,rgba(24,20,29,0.92),rgba(10,10,16,0.92));">
          <div class="eyebrow">Qué encontrás</div>

          <ul class="bullet-list">
            {page.bullets.map((item) => (
              <li class="bullet-item">
                <span class="icon-badge">✦</span>
                <span style="line-height:1.7;color:var(--text);">{item}</span>
              </li>
            ))}
          </ul>

          <div class="card" style="margin-top:22px;background:rgba(0,0,0,0.2);padding:18px 20px;">
            <div class="eyebrow" style="color:var(--dim);">Foco SEO</div>
            <p style="margin:10px 0 0;line-height:1.8;color:var(--text);">
              {page.focus} y búsquedas relacionadas, con acceso completo solo después del registro dentro de la comunidad privada.
            </p>
          </div>
        </aside>
      </section>

      <section class="split-section">
        <article class="card">
          <h2 style="margin:0;font-size:1.7rem;">Preguntas frecuentes</h2>
          <div style="margin-top:18px;">
            {page.faq.map(([question, answer]) => (
              <div class="faq-item" style="border-radius:22px;border:1px solid rgba(255,255,255,0.06);background:rgba(0,0,0,0.15);padding:18px;">
                <h3>{question}</h3>
                <p>{answer}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="card" style="background:linear-gradient(180deg,rgba(214,177,109,0.08),rgba(24,20,29,0.88));">
          <h2 style="margin:0;font-size:1.7rem;">Últimas búsquedas</h2>
          <p class="dim" style="margin:10px 0 0;line-height:1.8;">
            Desde esta familia ampliamos otras intenciones relacionadas para que el interlinking se mantenga natural y útil para quien navega.
          </p>
          <div class="tag-list" style="margin-top:18px;">
            {RELATED_KEYWORDS
              .filter((item) => item.to !== `/${variant}`)
              .map((item) => (
                <a class="tag-link" href={item.to}>{item.label}</a>
              ))}
          </div>

          <div class="card" style="margin-top:22px;background:rgba(0,0,0,0.2);padding:18px 20px;">
            <div class="eyebrow" style="color:var(--dim);">Acceso completo</div>
            <p style="margin:10px 0 0;line-height:1.8;color:var(--text);">
              La landing es pública para captar la búsqueda correcta. El detalle de perfiles, stories y mensajes vive detrás del login.
            </p>
          </div>
        </article>
      </section>
    </div>
  </main>
</BaseLayout>
