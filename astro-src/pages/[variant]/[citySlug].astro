---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SEO_INTENT_VARIANTS, isSeoIntentVariant } from '../../../src/lib/seoVariants.js';
import { GEO_SLUGS } from '../../../src/lib/seoGeoCatalog.js';
import { getAstroLandingData, RELATED_KEYWORDS } from '../../lib/landingData.js';
import { APP_SITE_ORIGIN } from '../../../src/lib/siteDomains.js';

export function getStaticPaths() {
  return SEO_INTENT_VARIANTS.flatMap((variant) =>
    GEO_SLUGS.map((citySlug) => ({
      params: { variant, citySlug },
    })),
  );
}

const { variant, citySlug } = Astro.params;

if (!isSeoIntentVariant(variant)) {
  throw new Error(`Invalid SEO variant: ${variant}`);
}

const {
  localeConfig,
  page,
  city,
  cityHasStats,
  cityStats,
  canonical,
  alternates,
  relatedCityLinks,
  faqSchema,
  pageSchema,
} = getAstroLandingData({ variant, citySlug });

const keywordPills = ['encuentros discretos', 'perfiles verificados', 'adultos registrados', 'contactos privados'];
const stats = cityHasStats
  ? [
      ['Parejas', cityStats.active_couples_30d],
      ['Mujeres', cityStats.active_women_30d],
      ['Hombres', cityStats.active_men_30d],
      ['Premium', cityStats.premium_profiles],
    ]
  : [];
---
<BaseLayout
  title={page.title}
  description={page.description}
  canonical={canonical}
  alternates={alternates}
  htmlLang={localeConfig.language}
  ogLocale={localeConfig.hreflang.replace('-', '_')}
  schemas={[faqSchema, pageSchema]}
>
  <main class="page-frame">
    <div class="page-background">
      <div class="background-blob left"></div>
      <div class="background-blob right"></div>
    </div>

    <div class="page-shell section-spaced" style="position:relative;">
      <header class="topbar" style="padding-top:0;margin-bottom:40px;">
        <a class="brand" href="/">
          <span class="brand-mark">M</span>
          <span>
            <strong class="brand-title">Mansión Deseo</strong>
            <span class="dim" style="display:block;font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;">Acceso privado para adultos</span>
          </span>
        </a>

        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a class="secondary-button" href={`${APP_SITE_ORIGIN}/login`}>Iniciar sesión</a>
          <a class="primary-button" href={`${APP_SITE_ORIGIN}/registro`}>Registrarme</a>
        </div>
      </header>

      <section class="landing-hero-grid">
        <section>
          <div class="tag-list">
            <span class="pill"><span class="pill-dot"></span>SEO local</span>
            <span class="pill"><span class="pill-dot"></span>{city?.label || citySlug}</span>
            <span class="pill"><span class="pill-dot"></span>Acceso privado</span>
          </div>

          <h1 class="headline" style="max-width:18ch;">{page.headline}</h1>
          <p class="subheadline">{page.intro}</p>

          <div class="tag-list" style="margin-top:20px;">
            {keywordPills.map((item) => (
              <span class="tag-link">{item}</span>
            ))}
          </div>

          <div class="feature-grid">
            <div class="card">
              <div class="feature-icon">L</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Intención + ciudad</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">La URL cruza la intención SEO con {city?.label || citySlug} para servir una entrada pública más precisa.</p>
            </div>
            <div class="card">
              <div class="feature-icon">S</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Señal local</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">Cuando hay datos verificados, la landing muestra actividad agregada y actualizada por ciudad.</p>
            </div>
            <div class="card">
              <div class="feature-icon">R</div>
              <p style="margin:16px 0 0;font-size:0.95rem;font-weight:600;">Registro como destino</p>
              <p class="dim" style="margin:8px 0 0;line-height:1.7;font-size:0.88rem;">La experiencia completa se abre dentro de la app privada, no en la URL pública.</p>
            </div>
          </div>

          <div class="button-row">
            <a class="primary-button" href={`${APP_SITE_ORIGIN}/registro`}>Crear cuenta</a>
            <a class="secondary-button" href={`/${variant}`}>Ver categoría base</a>
          </div>
        </section>

        <aside class="surface" style="padding:28px;border-radius:32px;background:linear-gradient(180deg,rgba(24,20,29,0.92),rgba(10,10,16,0.92));">
          <div class="eyebrow">Qué encontrás</div>

          <ul class="bullet-list">
            {page.bullets.map((item) => (
              <li class="bullet-item">
                <span class="icon-badge">✦</span>
                <span style="line-height:1.7;color:var(--text);">{item}</span>
              </li>
            ))}
          </ul>

          <div class="card" style="margin-top:22px;background:rgba(0,0,0,0.2);padding:18px 20px;">
            <div class="eyebrow" style="color:var(--dim);">Actividad local</div>
            {cityHasStats ? (
              <>
                <p style="margin:10px 0 0;line-height:1.8;color:var(--text);">
                  Hay {cityStats.active_profiles_30d} perfiles verificados activos en los últimos 30 días {city?.cityHint || ''}.
                </p>
                <div class="metric-grid">
                  {stats.map(([label, value]) => (
                    <div class="metric-card">
                      <p class="metric-label">{label}</p>
                      <p class="metric-value">{value}</p>
                    </div>
                  ))}
                </div>
                <p class="dim" style="margin:12px 0 0;font-size:0.82rem;line-height:1.7;">
                  Datos agregados y actualizados para reforzar la landing local sin volverla un panel.
                </p>
              </>
            ) : (
              <p style="margin:10px 0 0;line-height:1.8;color:var(--text);">
                Esta landing ya está preparada para captar búsquedas de alta intención {city?.cityHint || ''}. Cuando haya volumen agregado suficiente, mostramos cifras públicas más precisas.
              </p>
            )}
          </div>
        </aside>
      </section>

      <section class="split-section">
        <article class="card">
          <h2 style="margin:0;font-size:1.7rem;">Preguntas frecuentes</h2>
          <div style="margin-top:18px;">
            {page.faq.map(([question, answer]) => (
              <div class="faq-item" style="border-radius:22px;border:1px solid rgba(255,255,255,0.06);background:rgba(0,0,0,0.15);padding:18px;">
                <h3>{question}</h3>
                <p>{answer}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="card" style="background:linear-gradient(180deg,rgba(214,177,109,0.08),rgba(24,20,29,0.88));">
          <h2 style="margin:0;font-size:1.7rem;">{relatedCityLinks.length ? 'Otras ciudades activas' : 'Últimas búsquedas'}</h2>
          <p class="dim" style="margin:10px 0 0;line-height:1.8;">
            {relatedCityLinks.length
              ? 'Estas ciudades ya muestran actividad verificada y ayudan a reforzar el interlinking de la misma familia SEO.'
              : 'Desde esta familia ampliamos otras intenciones relacionadas para mantener una navegación útil y coherente.'}
          </p>

          <div class="tag-list" style="margin-top:18px;">
            {(relatedCityLinks.length ? relatedCityLinks : RELATED_KEYWORDS.filter((item) => item.to !== `/${variant}`)).map((item) => (
              <a class="tag-link" href={item.to}>{item.label}</a>
            ))}
          </div>

          <div class="card" style="margin-top:22px;background:rgba(0,0,0,0.2);padding:18px 20px;">
            <div class="eyebrow" style="color:var(--dim);">Adentro de la app</div>
            <p style="margin:10px 0 0;line-height:1.8;color:var(--text);">
              La landing pública captura la búsqueda local. El detalle de perfiles, stories y mensajes vive dentro del sitio, detrás del registro.
            </p>
          </div>
        </article>
      </section>
    </div>
  </main>
</BaseLayout>
