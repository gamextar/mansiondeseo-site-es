---
import BaseLayout from '../layouts/BaseLayout.astro';
import heroTrioPremium from '../../src/assets/hero-trio-premium.svg';
import { getTopSeoCityStats, formatSeoCityStatsDate } from '../../src/lib/seoCityStats.js';
import { getSeoHomeStats, formatSeoHomeStatsDate } from '../../src/lib/seoHomeStats.js';
import { APP_SITE_ORIGIN } from '../../src/lib/siteDomains.js';

const countFormatter = new Intl.NumberFormat('es-AR');
const homeStats = getSeoHomeStats();
const updatedLabel = formatSeoHomeStatsDate(homeStats?.updated_at) || formatSeoCityStatsDate(homeStats?.updated_at);
const totalActive = Number(homeStats?.active_profiles_30d || 0);
const couplesActive = Number(homeStats?.active_couples_30d || 0);
const womenActive = Number(homeStats?.active_women_30d || 0);
const menActive = Number(homeStats?.active_men_30d || 0);
const topCities = getTopSeoCityStats(4);

const intentLinks = [
  { to: '/parejas-liberales', label: 'Parejas liberales' },
  { to: '/trios', label: 'Trios' },
  { to: '/swingers', label: 'Swingers' },
  { to: '/intercambio-de-parejas', label: 'Intercambio' },
  { to: '/cornudos-argentina', label: 'Cornudos' },
  { to: '/cornudos-argentina', label: 'Maridos cornudos' },
  { to: '/cuckold-argentina', label: 'Cuckold' },
  { to: '/hotwife-argentina', label: 'Hotwife' },
  { to: '/contactossex', label: 'Contactossex' },
];

const featureCards = [
  {
    icon: 'A',
    title: 'Afinidad mejor filtrada',
    text: 'Parejas, mujeres, hombres y nichos concretos dentro de una experiencia privada más cuidada.',
  },
  {
    icon: 'M',
    title: 'SEO por ciudad e intención',
    text: 'La capa pública capta búsquedas reales y la experiencia completa vive adentro, detrás del registro.',
  },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Mansion Deseo',
    url: 'https://mansiondeseo.com/',
  },
];

function formatCount(value) {
  return countFormatter.format(value || 0);
}
---
<BaseLayout
  title="Mansion Deseo | Club privado para adultos registrados"
  description="Comunidad privada para adultos registrados, pensada para parejas liberales, swingers, trios y conexiones discretas con perfiles verificados."
  canonical="https://mansiondeseo.com/"
  alternates={[{ hrefLang: 'es-AR', href: 'https://mansiondeseo.com/' }]}
  htmlLang="es"
  ogLocale="es_AR"
  schemas={schemas}
>
  <div class="page-frame">
    <div class="page-background">
      <div class="background-blob left"></div>
      <div class="background-blob right"></div>
    </div>

    <main class="page-shell section-spaced" style="position:relative;z-index:1;">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">M</span>
          <span>
            <span class="brand-title">Mansion Deseo</span>
            <span class="dim" style="display:block;font-size:0.64rem;letter-spacing:0.22em;text-transform:uppercase;">Club privado para adultos</span>
          </span>
        </a>

        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
          <a class="text-link" href={`${APP_SITE_ORIGIN}/login`}>Acceder</a>
          <a class="primary-button" style="padding:10px 16px;font-size:0.9rem;" href={`${APP_SITE_ORIGIN}/registro`}>Registro gratis</a>
        </div>
      </header>

      <section style="padding:56px 0 0;">
        <div class="surface" style="overflow:hidden;border-radius:2.4rem;padding:16px;background:linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02));box-shadow:0 30px 100px rgba(0,0,0,0.38);">
          <div class="hero-grid surface" style="padding:20px;border-radius:2rem;background:rgba(0,0,0,0.25);box-shadow:none;">
            <div class="hero-copy" style="height:100%;">
              <span class="chip" style="width:max-content;">+18 · Acceso privado para adultos</span>
              <h1 class="headline" style="max-width:14ch;line-height:1.02;font-size:clamp(2.6rem,6vw,4.4rem);">
                Una entrada pública más cuidada para una comunidad privada.
              </h1>
              <p class="subheadline" style="max-width:34rem;font-size:1.02rem;">
                Landings pensadas para captar búsquedas reales y llevarlas a una experiencia
                cerrada con perfiles verificados, historias y mensajes dentro de la app.
              </p>
              <div class="button-row" style="margin-top:30px;">
                <a class="primary-button" href={`${APP_SITE_ORIGIN}/registro`}>Empezar ahora</a>
                <a class="secondary-button" href={`${APP_SITE_ORIGIN}/login`}>Ya tengo cuenta</a>
              </div>
            </div>

            <div style="display:flex;height:100%;flex-direction:column;">
              <div class="hero-art" style="flex:1;min-height:420px;border-radius:1.9rem;background:rgba(0,0,0,0.25);">
                <img
                  src={heroTrioPremium.src}
                  width={heroTrioPremium.width}
                  height={heroTrioPremium.height}
                  alt="Tres figuras adultas en una composición elegante y sensual"
                />
              </div>
            </div>
          </div>

          <div class="card" style="margin-top:20px;border-radius:1.8rem;background:rgba(255,255,255,0.04);">
            <div class="panel-grid" style="align-items:center;">
              <div>
                <p class="eyebrow" style="color:rgba(214,177,109,0.8);">Comunidad activa</p>
                <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:14px;margin-top:10px;">
                  <p class="stat-number" style="margin:0;font-size:clamp(3rem,6vw,4.4rem);">{formatCount(totalActive)}</p>
                  <p class="muted" style="max-width:16rem;margin:0 0 8px;">perfiles activos en los últimos 30 días</p>
                </div>
              </div>

              <div class="tag-list" style="justify-content:flex-start;">
                <span class="tag-link" style="color:rgba(255,255,255,0.92);">Parejas · {formatCount(couplesActive)}</span>
                <span class="tag-link" style="color:rgba(255,255,255,0.92);">Mujeres · {formatCount(womenActive)}</span>
                <span class="tag-link" style="color:rgba(255,255,255,0.92);">Hombres · {formatCount(menActive)}</span>
              </div>
            </div>
          </div>

          <div class="panel-grid" style="margin-top:20px;">
            <section class="card" style="border-radius:1.7rem;">
              <div style="display:flex;flex-wrap:wrap;align-items:center;gap:12px;font-size:0.7rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--dim);">
                <span>Ultimas busquedas</span>
                <span style="width:4px;height:4px;border-radius:999px;background:rgba(214,177,109,0.7);"></span>
                <span>Actualizado {updatedLabel || 'hoy'}</span>
              </div>
              <div class="tag-list" style="margin-top:16px;">
                {intentLinks.map((item) => (
                  <a class="tag-link" href={item.to}>{item.label}</a>
                ))}
              </div>
            </section>

            <section class="card" style="border-radius:1.7rem;">
              <p class="eyebrow" style="display:flex;align-items:center;gap:8px;color:var(--dim);">
                <span style="color:var(--gold);font-size:0.9rem;">•</span>
                Ciudades activas
              </p>
              <div class="tag-list" style="margin-top:16px;">
                {topCities.map((city) => (
                  <a class="tag-link" href={`/contactossex/${city.city_slug}`}>
                    {city.locality || city.city_slug}
                  </a>
                ))}
              </div>
            </section>
          </div>
        </div>
      </section>

      <section class="feature-grid">
        {featureCards.map((card) => (
          <article class="card" style="border-radius:1.7rem;background:rgba(255,255,255,0.04);">
            <div class="feature-icon">{card.icon}</div>
            <h2 style="margin:16px 0 0;font-size:1.1rem;">{card.title}</h2>
            <p class="muted" style="margin:10px 0 0;line-height:1.8;">{card.text}</p>
          </article>
        ))}
      </section>
    </main>
  </div>
</BaseLayout>
